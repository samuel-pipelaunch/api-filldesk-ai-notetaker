# =============================================================================
# FillDesk AI Notetaker — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the actual values.
# NEVER commit the .env file. Only .env.example should be in version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Recall.ai API
# -----------------------------------------------------------------------------
# Recall.ai workspaces (one per stage, per region):
#   - "PipeLaunch GmbH"  → personal-dev
#   - "staging"           → staging
#   - "prod"              → production
#
# Each workspace has its own API key and webhook secret.
# The values below correspond to the workspace matching the current STAGE.
# Get keys from https://recall.ai dashboard → Developers → API Keys & Secrets.
#
# API keys for Recall.ai regions.
RECALL_API_KEY_US=
RECALL_API_KEY_EU=

# Webhook verification secrets (per region, per workspace).
# Create from dashboard: Developers → API Keys & Secrets → Create Workspace Secret.
RECALL_WEBHOOK_SECRET_US=
RECALL_WEBHOOK_SECRET_EU=

# -----------------------------------------------------------------------------
# Google OAuth 2.0
# -----------------------------------------------------------------------------
# OAuth credentials for Google Calendar integration.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
# AWS region for primary deployments.
AWS_REGION=us-west-2

# AWS SSO profile name for local development.
# Each developer has their own profile (e.g., AdministratorAccess-754437491056).
AWS_PROFILE=

# Stage identifier: personal-dev | staging | production
STAGE=personal-dev

# -----------------------------------------------------------------------------
# AWS Account IDs (non-secret, used for deployment scripts)
# -----------------------------------------------------------------------------
# These are used by deployment tooling to target the correct account.
# AWS_ACCOUNT_ID_DEV is per-developer (Sam's: 754437491056).
AWS_ACCOUNT_ID_DEV=754437491056
AWS_ACCOUNT_ID_STAGING=471112515517
AWS_ACCOUNT_ID_PROD=975050325894

# -----------------------------------------------------------------------------
# AWS Deployment Roles (used by CI/CD)
# -----------------------------------------------------------------------------
# IAM role ARNs assumed by GitHub Actions for deployments.
# These are created during infrastructure setup.
AWS_DEPLOY_ROLE_ARN_STAGING=
AWS_DEPLOY_ROLE_ARN_PROD=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Application port for the API server.
PORT=3000

# Node environment.
NODE_ENV=development

# Application log level.
LOG_LEVEL=debug