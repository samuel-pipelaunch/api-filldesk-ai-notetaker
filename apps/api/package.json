{
  "name": "@filldesk/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.887.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/sensible": "^6.0.3",
    "@filldesk/shared-types": "workspace:*",
    "drizzle-orm": "^0.39.1",
    "fastify": "^5.2.1",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@fastify/aws-lambda": "^5.1.0",
    "@types/node": "^22.12.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}